# IBM Informix Docker image
IFX_IMAGE=icr.io/informix/informix-developer-database:15.0.0.0
IFX_LICENSE=accept
IFX_CONTAINER_NAME=ifx
IFX_HOSTNAME=ifx
IFX_TYPE=oltp
IFX_SIZE=small
IFX_SHM_SIZE=1gb

# Exposed ports on the host
IFX_PORT=9088
IFX_DRDA_PORT=9089
IFX_MONGO_PORT=27017
IFX_REST_PORT=27018
IFX_MQTT_PORT=27883

# Test database bootstrapped by scripts/ifx-bootstrap.sh
IFX_DB=ifx_test

# Default credentials shipped by the official developer image
IFX_USER=informix
IFX_PASSWORD=in4mix

# ODBC / SQLAlchemy connection settings used by this fork
IFX_ODBC_DRIVER=IBM INFORMIX ODBC DRIVER (64-bit)
IFX_SERVER=ifx
IFX_PROTOCOL=onsoctcp
IFX_HOST=127.0.0.1

# Host-run tests (Python + pyodbc on the host machine)
INFORMIX_SQLALCHEMY_URL=informix+pyodbc://informix:in4mix@127.0.0.1/ifx_test?driver=IBM+INFORMIX+ODBC+DRIVER+(64-bit)&protocol=onsoctcp&server=ifx&service=9088&DELIMIDENT=Y

# Third-party SQLAlchemy suite. Keep it aligned with the same local target.
INFORMIX_SQLALCHEMY_SUITE_URL=informix+pyodbc://informix:in4mix@127.0.0.1/ifx_test?driver=IBM+INFORMIX+ODBC+DRIVER+(64-bit)&protocol=onsoctcp&server=ifx&service=9088&DELIMIDENT=Y
